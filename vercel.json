{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(index.html)?",
      "dest": "public/index.html"
    },
    {
      "src": "/blog(.html)?",
      "dest": "public/blog.html"
    },
    {
      "src": "/login(.html)?",
      "dest": "public/login.html"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}
